{
  "version": 6,
  "configurePresets": [
    {
      "name": "local-debug-no-deps",
      "displayName": "Local Debug without external dependencies",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/local-debug-no-deps",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NOVACORE_ENABLE_SDL3": "OFF",
        "NOVACORE_ENABLE_VULKAN": "OFF"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-vs2022-no-deps",
      "displayName": "Windows Visual Studio 2022 without external dependencies",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2022-no-deps",
      "cacheVariables": {
        "NOVACORE_ENABLE_SDL3": "OFF",
        "NOVACORE_ENABLE_VULKAN": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Linux Clang Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "local-debug-no-deps",
      "configurePreset": "local-debug-no-deps"
    },
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug"
    },
    {
      "name": "windows-vs2022-no-deps",
      "configurePreset": "windows-vs2022-no-deps",
      "configuration": "Debug"
    },
    {
      "name": "linux-clang-debug",
      "configurePreset": "linux-clang-debug"
    }
  ]
}







